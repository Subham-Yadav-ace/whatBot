# ============================================================
# AIT Placement Bot — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# ----------------------------
# Placement Portal
# ----------------------------
PORTAL_BASE_URL=https://your-portal-domain.com
PORTAL_AUTH_TOKEN_PATH=/api/auth/token
PORTAL_POST_LIST_PATH=/api/post/list
PORTAL_POST_DETAIL_PATH=/api/post
PORTAL_ATTACHMENT_PATH=/api/attachment
SESSION_COOKIE_NAME=__Secure-better-auth.session_token

# ----------------------------
# MongoDB
# ----------------------------
MONGO_URI=mongodb://localhost:27017/placement-bot

# ----------------------------
# Redis (BullMQ)
# ----------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------
# AWS S3 (storageState.json session storage)
# ----------------------------
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-s3-bucket-name
S3_STORAGE_STATE_KEY=auth/storageState.json


# ----------------------------
# Gemini AI (summarization)
# ----------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ----------------------------
# Admin Alerts (Telegram)
# ----------------------------
ADMIN_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ADMIN_TELEGRAM_CHAT_ID=your-telegram-chat-id

# ----------------------------
# Sync Timing
# ----------------------------
SYNC_INTERVAL_MS=300000

# ----------------------------
# WhatsApp (whatsapp-web.js)
# ----------------------------
WHATSAPP_AUTH_FOLDER=./whatsapp_auth
WHATSAPP_SEND_DELAY_MS=1500
WHATSAPP_GROUP_ID=

# ----------------------------
# Daily Digest
# ----------------------------
DAILY_DIGEST_CRON=0 9 * * *

# ----------------------------
# App
# ----------------------------
NODE_ENV=development
LOG_LEVEL=info
